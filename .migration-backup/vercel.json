{
  "buildCommand": "BASE_PATH=/ pnpm --filter @workspace/zman-app run build",
  "outputDirectory": "artifacts/zman-app/dist/public",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "dest": "/api/index" },
    { "source": "/((?!api/).*)", "dest": "/index.html" }
  ]
}
